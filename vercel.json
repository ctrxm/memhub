{
  "version": 2,
  "installCommand": "pnpm install --frozen-lockfile",
  "functions": {
    "artifacts/api-server/api/index.ts": {
      "includeFiles": "lib/**",
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "artifacts/api-server/api/index.ts"
    }
  ]
}
